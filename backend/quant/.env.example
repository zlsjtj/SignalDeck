# Quant API Backend environment example

# Core
DEFAULT_STRATEGY_CONFIG_PATH=config_2025_bch_bnb_btc_equal_combo_baseline_v2_invvol_best.yaml
MARKET_INTEL_CONFIG_PATH=config_market.yaml
MARKET_INTEL_STREAM_ENABLED=true
MARKET_INTEL_STREAM_SYMBOL_LIMIT=4
CORS_ORIGINS=http://localhost:5173

# Auth
API_AUTH_REQUIRED=true
API_AUTH_TOKEN=replace-with-strong-token
API_AUTH_TOKEN_FILE=

# Dashboard login
DASHBOARD_LOGIN_USERNAME=admin
DASHBOARD_LOGIN_PASSWORD=replace-with-strong-password
DASHBOARD_AUTH_FILE=
DASHBOARD_GUEST_USERNAME=guest

# Session
API_SESSION_SECRET=replace-with-long-random-secret
API_SESSION_SECRET_FILE=
API_SESSION_COOKIE_NAME=quant_session
API_SESSION_TTL_SECONDS=43200
API_SESSION_COOKIE_SECURE=false
API_SESSION_COOKIE_SAMESITE=lax

# Login rate limit
API_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
API_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
API_LOGIN_LOCKOUT_SECONDS=900

# DB
API_DB_ENABLED=true
API_DB_BACKEND=postgres
API_DB_PATH=/dev/null
API_DB_POSTGRES_DSN=postgresql://quant_user:change-me@127.0.0.1:5432/quant_db
API_DB_POSTGRES_POOL_ENABLED=true
API_DB_POSTGRES_POOL_MIN_SIZE=1
API_DB_POSTGRES_POOL_MAX_SIZE=10
API_DB_POSTGRES_POOL_TIMEOUT_SECONDS=5
API_DB_HEALTH_STATS_TTL_SECONDS=30
API_DB_SLOW_OP_THRESHOLD_MS=200
API_BACKTEST_CREATE_DEDUP_TTL_SECONDS=30
API_BACKTEST_PROGRESS_PERSIST_INTERVAL_SECONDS=10
API_BACKTEST_PROGRESS_MIN_DELTA_PCT=1
API_STRATEGY_COMPILE_WAIT_SECONDS=0.25

# DB alerting (optional)
API_DB_ALERT_WEBHOOK_URL=
API_DB_ALERT_THRESHOLD=1
API_DB_ALERT_COOLDOWN_SECONDS=300
API_DB_ALERT_TIMEOUT_SECONDS=3
API_DB_ALERT_MAX_RETRIES=0
API_DB_ALERT_RETRY_BACKOFF_MS=200
API_DB_ALERT_OUTBOX_ENABLED=true
API_DB_ALERT_OUTBOX_POLL_SECONDS=1
API_DB_ALERT_OUTBOX_BATCH_SIZE=20
